<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_home_cyber">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SeniorCare SOS"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#E0F2FE"
        android:layout_marginBottom="36dp"/>

    <!-- 🔥 FIXED SOS AREA (NO MOVEMENT) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_gravity="center"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- GREEN WAVE (BEHIND) -->
        <View
            android:id="@+id/waveView"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_green_wave_circle"
            android:alpha="0.6"/>

        <!-- SOS BUTTON (ON TOP – FIXED) -->
        <Button
            android:id="@+id/btnSOS"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:text="SOS"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_sos_neon_circle"
            android:elevation="16dp"/>

    </FrameLayout>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap for Emergency"
        android:textSize="15sp"
        android:textColor="#94A3B8"
        android:layout_marginTop="18dp"/>

    <!-- Save Contact Button -->
    <Button
        android:id="@+id/btnEditContacts"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="SAVE EMERGENCY CONTACTS"
        android:textAllCaps="true"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="50dp"
        android:background="@drawable/bg_cyber_red_button"
        android:elevation="10dp"/>

</LinearLayout>
